' appsec-style.puml
' Common styling for AppSec process diagrams.
' Design goals: clear purpose, consistent layout, minimal palette, and high legibility.

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 10

skinparam defaultFontName Arial
skinparam defaultFontSize 12

skinparam ArrowColor #444444
skinparam ActivityBorderColor #444444
skinparam ActivityBackgroundColor #F7F7F7
skinparam ActivityDiamondBorderColor #444444
skinparam ActivityDiamondBackgroundColor #F7F7F7
skinparam ActivityBarColor #444444

skinparam NoteBackgroundColor #FFF8D6
skinparam NoteBorderColor #C7A700

' Highlight key gates with a third, subtle color (blue).
skinparam activity {
  BackgroundColor<<gate>> #E9F5FF
  BorderColor<<gate>> #2F6FAB
  FontColor<<gate>> #123A5A
}

' Keep partitions visually clean.
skinparam PartitionBorderColor #777777
skinparam PartitionFontColor #111111

skinparam TitleFontSize 16
skinparam TitleFontStyle bold

' Optional: legend styling
skinparam LegendBackgroundColor #FFFFFF
skinparam LegendBorderColor #777777
