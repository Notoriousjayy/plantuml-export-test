@startuml
!include ../includes/appsec-style.puml
title AppSec Process 12: Non-Compliant Application Handling (Coverage, SLAs, and Exceptions)

' Purpose: Provide a clear, enforceable path when an application is non-compliant
'          (missing scans, missing AppCode, overdue criticals, repeated gate bypass).

start

partition "Detect Non-Compliance" {
  :Trigger (audit/metrics/event);
  :Identify AppCode (or flag **missing AppCode**);
  :Classify non-compliance type:
  - Missing coverage (SAST/SCA/DAST/IAST/Trivy)
  - SLA breach (critical/high overdue)
  - Repeated gate bypass
  - Vendor delay (COTS/SaaS);
}

partition "Assess" {
  :Confirm scope + exposure (install model, envs);
  if (Customer/regulated data?) then (Yes)
    :Raise priority;
  else (No)
    :Standard priority;
  endif
}

partition "Risk Treatment" {
  if (Can remediate quickly?) then (Yes)
    :Create remediation plan (owner + dates);
  else (No)
    :Define compensating controls;
    :Time-boxed waiver (approval required);
  endif
}

partition "Enforcement" {
  if (Release must be blocked?) then (Yes)
    :Freeze release / block promotion<<gate>>;
  else (No)
    :Allow limited release with controls;
  endif
  :Escalate to leadership as required;
}

partition "Verify & Restore Compliance" {
  :Execute plan (fix/patch/config);
  :Re-scan/re-test (sources as applicable);
  :Update compliance status + evidence;
}

note right
Key message: **Non-compliance has a predictable outcome**:
remediate, mitigate-with-waiver, or freeze.
end note

stop
@enduml
