@startuml
!include ../includes/appsec-style.puml
title AppSec Process 06: Container & IaC Scanning (Trivy)

' Purpose: Detect vulnerable images, misconfigurations, and IaC issues and tie results to AppCode.

start

partition "Prepare" {
  :Attach AppCode to image tags / build labels;
  :Select scan targets (IaC, images, SBOM);
}

partition "Scan" {
  :Trivy config scan (IaC/K8s/Cloud);
  :Trivy image scan (OS + packages);
  :Trivy SBOM generation;
}

partition "Evaluate" {
  if (Critical/high?) then (Yes)
    :Fail pipeline stage<<gate>>;
  else (No)
    :Allow with SLAs;
  endif
}

partition "Remediate" {
  :Update base image / dependencies;
  :Fix misconfigurations (policy-as-code);
  :Rebuild + rescan;
}

partition "Publish" {
  :Publish SBOM + scan report (AppCode);
  :Feed vulnerability lifecycle tracking;
}

note right
Key message: **You ship what you build** — scan artifacts and infrastructure, not just source.
end note

stop
@enduml
