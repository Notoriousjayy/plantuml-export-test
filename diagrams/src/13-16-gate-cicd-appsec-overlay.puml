@startuml
!include ../includes/appsec-style.puml
title AppSec Process 13: 16-Gate CI/CD Pipeline — AppSec Overlay (AppCode-Centric)

' Purpose: Show where each AppSec process/tool fits within the 16-gate CI/CD pipeline.
'          Gate names align to the "CI/CD Pipeline with 16 Gates" reference.

start

partition "Source Code Management" {
  :Source Code Version Control<<gate>>;
  note right
  AppCode requirements:
  - Repo/pipeline tagged with AppCode
  - Ownership mapping (AppCode -> team)
  Related processes: 01, 02, 09
  end note

  :Optimum Branching Strategy<<gate>>;
  note right
  Controls:
  - Protected branches + required reviews
  - Required status checks (quality + security)
  Related processes: 02
  end note
}

partition "Build & Quality" {
  :Static Analysis<<gate>>;
  note right
  Tools:
  - SonarQube (11)
  - GHAS CodeQL / Coverity (03)
  Related processes: 02, 03, 11
  end note

  :80% Code Coverage<<gate>>;
  note right
  Controls:
  - Unit tests + coverage threshold
  Related processes: 02
  end note
}

partition "Security Scanning" {
  :Vulnerability Scan<<gate>>;
  note right
  Tools:
  - Trivy (IaC, images, SBOM) (06)
  - GHAS CodeQL findings contribute (03)
  Related processes: 02, 06, 09
  end note

  :Open Source Scan<<gate>>;
  note right
  Tools:
  - GHAS dependency review + Dependabot (04)
  - License policy checks (04)
  Related processes: 04, 09
  end note
}

partition "Artifact Management" {
  :Artifact Version Control<<gate>>;
  note right
  Controls:
  - Immutable, versioned artifacts
  - Labels include AppCode + build metadata
  Related processes: 06, 09
  end note
}

partition "Infrastructure Provisioning" {
  :Automatic Provision<<gate>>;
  :Immutable Servers<<gate>>;
  note right
  Controls:
  - IaC-defined infrastructure
  - Immutable image bake
  - Trivy config scan supports IaC assurance (06)
  Related processes: 06
  end note
}

partition "Integration & Performance" {
  :Integration Testing<<gate>>;
  note right
  Tools:
  - DAST (InsightAppSec) against test envs (07)
  - IAST (Seeker) during functional tests (08)
  Related processes: 07, 08
  end note

  :Performance Testing<<gate>>;
  note right
  Controls:
  - Load/latency thresholds
  - Security impact: rate limits, stability under load
  Related processes: 09 (risk prioritization)
  end note
}

partition "Automation & Release" {
  :Full Automation on Commit<<gate>>;
  note right
  Controls:
  - Commit -> build -> test -> scan -> deploy
  - Fail-fast + consistent evidence trails (AppCode)
  Related processes: 02, 09
  end note

  :Zero Downtime Release<<gate>>;
  :Feature Toggle<<gate>>;
  note right
  Controls:
  - Progressive delivery (blue/green/canary)
  - Feature flags for safe rollout
  Related processes: 12 (non-compliance enforcement)
  end note
}

partition "Change Management" {
  :Automated Change Order<<gate>>;
  :Automated Rollback<<gate>>;
  note right
  Controls:
  - Auto change records include AppCode + risk summary
  - Rollback on health/SLO breach
  Related processes: 09, 12
  end note
}

stop

legend left
**Process crosswalk (IDs):**
01 Onboarding & coverage plan
02 CI security gates
03 Static analysis triage (GHAS/Coverity/SonarQube)
04 SCA & dependencies
05 Secret scanning response
06 Trivy container/IaC/SBOM
07 DAST (InsightAppSec)
08 IAST verified (Seeker)
09 Unified vulnerability lifecycle
10 COTS/SaaS vendor risk
11 SonarQube quality gate
12 Non-compliant app handling
endlegend
@enduml
